# Copy this file to .env and fill in your credentials.
# Generate ICLOUD_APP_PASSWORD at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords

ICLOUD_USERNAME=you@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Set to 1 to disable all destructive tools (create/update/delete).
# Recommended while you're still gaining trust in the integration.
ICLOUD_MCP_READ_ONLY=0

# Comma-separated additional emails the user is identified by. Apple often
# delivers invites and mail to @me.com or @mac.com aliases of an @icloud.com
# account; without this, respond_to_invite will fail to find the user's
# attendee record. Example: me@me.com,me@mac.com
ICLOUD_USER_ALIASES=

# IANA timezone name used by today_brief and other workflow tools to
# determine "today's" boundaries. Defaults to UTC if unset, which usually
# isn't what you want. Example: America/Los_Angeles
ICLOUD_USER_TIMEZONE=
