# Exclude development and runtime artifacts from the .mcpb bundle
.git/
.gitignore
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# User data — must not be in the bundle
.env

# Tests aren't needed at runtime
tests/

# Local notes / scripts not needed for end users
scripts/

# OS junk
.DS_Store
Thumbs.db

# uv lock — let the host resolve fresh against pyproject.toml
uv.lock
